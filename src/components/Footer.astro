---
import { site } from "../data/site";
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <p class="fb-name">{site.name}</p>
      <p class="fb-role">{site.roles.join("  ·  ")}</p>
    </div>

    <div class="footer-links">
      {site.github && (
        <a href={site.github} target="_blank" rel="noopener" aria-label="GitHub">
          <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 .1.8 1.7 2.7 1.2.1-.7.4-1.2.7-1.5-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17 5 18 5.3 18 5.3c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .4.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z"/></svg>
        </a>
      )}
      {site.linkedin && (
        <a href={site.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M20.45 20.45h-3.56v-5.57c0-1.33 0-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14ZM7.12 20.45H3.56V9h3.56v11.45ZM22.22 0H1.77C.8 0 0 .78 0 1.74v20.5C0 23.2.8 24 1.77 24h20.45c.98 0 1.78-.8 1.78-1.76V1.74C24 .78 23.2 0 22.22 0Z"/></svg>
        </a>
      )}
      <a href={`mailto:${site.email}`} aria-label="Email">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
      </a>
    </div>
  </div>
  <div class="container">
    <p class="footer-note">© {year} {site.name}. Designed and developed from {site.location}.</p>
  </div>
</footer>

<style>
  .footer { background: var(--footer-bg); color: #fff; padding-block: 48px 32px; }
  .footer-inner {
    display: flex; align-items: center; justify-content: space-between;
    gap: 24px; flex-wrap: wrap;
    padding-bottom: 26px; margin-bottom: 22px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  .fb-name { font-family: var(--font-display); font-weight: 700; color: #fff; font-size: 1.1rem; }
  .fb-role { color: rgba(255, 255, 255, 0.6); font-size: 0.85rem; margin-top: 4px; }

  .footer-links { display: flex; gap: 12px; }
  .footer-links a {
    display: grid; place-items: center; width: 42px; height: 42px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.16);
    color: rgba(255, 255, 255, 0.75);
    transition: all 0.2s var(--ease);
  }
  .footer-links a:hover { background: var(--accent); border-color: var(--accent); color: #fff; transform: translateY(-2px); }

  .footer-note { font-size: 0.84rem; color: rgba(255, 255, 255, 0.5); }
</style>

---
import { withBase } from "../data/site";

interface Props {
  href: string;
  title: string;
  summary: string;
  category: string;
  date: string;
  cover?: string;
}
const { href, title, summary, category, date, cover } = Astro.props;
const link = withBase(href);
const img = withBase(cover || "/projects/placeholder.svg");
const fallback = withBase("/projects/placeholder.svg");
---

<article class="pcard reveal">
  <a href={link} class="pcard-media" aria-label={title}>
    <img src={img} alt={`${title} preview`} loading="lazy"
         onerror={`this.onerror=null;this.src='${fallback}'`} />
    <span class="pcard-cat">{category}</span>
  </a>
  <div class="pcard-body">
    <span class="pcard-date">{date}</span>
    <h3 class="pcard-title"><a href={link}>{title}</a></h3>
    <p class="pcard-summary">{summary}</p>
    <a class="btn btn-dark pcard-btn" href={link}>Read More</a>
  </div>
</article>

<style>
  .pcard {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease);
  }
  .pcard:hover { transform: translateY(-6px); box-shadow: var(--shadow-md); }

  .pcard-media {
    position: relative;
    display: block;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--bg-alt);
  }
  .pcard-media img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.5s var(--ease);
  }
  .pcard:hover .pcard-media img { transform: scale(1.05); }

  .pcard-cat {
    position: absolute;
    top: 14px; left: 14px;
    font-family: var(--font-display);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #fff;
    background: var(--accent);
    padding: 5px 12px;
    border-radius: 999px;
  }

  .pcard-body {
    padding: 26px 24px 28px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
  }
  .pcard-date {
    font-size: 0.78rem;
    color: var(--muted);
    letter-spacing: 0.04em;
    margin-bottom: 8px;
  }
  .pcard-title { font-size: 1.24rem; line-height: 1.3; }
  .pcard-title a { transition: color 0.2s var(--ease); }
  .pcard-title a:hover { color: var(--accent); }
  .pcard-summary {
    font-size: 0.94rem;
    color: var(--text);
    margin: 12px 0 22px;
  }
  .pcard-btn { margin-top: auto; }
</style>

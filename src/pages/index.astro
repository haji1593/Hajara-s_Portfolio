---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { site, withBase } from "../data/site";

const projects = (await getCollection("projects", ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);
const featured = projects.filter((p) => p.data.featured).slice(0, 4);
const firstName = site.name.split(" ")[0];
---

<Base>
  <!-- ================= HERO ================= -->
  <section class="hero" id="top" style={`background-image: url(${withBase("/hero-glass.png")})`}>
    <div class="hero-overlay"></div>

    <!-- Data-science motif: a faint neural-network graph + chart sparklines -->
    <svg class="hero-net" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <g class="net-edges">
        <path d="M120 180 L300 120 M120 180 L240 340 M300 120 L240 340 M240 340 L90 470 M240 340 L380 520 M90 470 L380 520 M300 120 L470 230 M380 520 L470 230" />
        <path d="M1320 200 L1180 140 M1320 200 L1260 380 M1180 140 L1260 380 M1260 380 L1380 470 M1260 380 L1100 520 M1380 470 L1100 520 M1180 140 L1010 250 M1100 520 L1010 250" />
        <path d="M520 770 L700 700 M700 700 L860 800 M520 770 L640 640 M860 800 L980 690" />
      </g>
      <g class="net-nodes">
        <circle cx="120" cy="180" r="4"/><circle cx="300" cy="120" r="5"/><circle cx="240" cy="340" r="4"/>
        <circle cx="90" cy="470" r="3"/><circle cx="380" cy="520" r="5"/><circle cx="470" cy="230" r="3"/>
        <circle cx="1320" cy="200" r="4"/><circle cx="1180" cy="140" r="5"/><circle cx="1260" cy="380" r="4"/>
        <circle cx="1380" cy="470" r="3"/><circle cx="1100" cy="520" r="5"/><circle cx="1010" cy="250" r="3"/>
        <circle cx="520" cy="770" r="4"/><circle cx="700" cy="700" r="5"/><circle cx="860" cy="800" r="4"/>
        <circle cx="640" cy="640" r="3"/><circle cx="980" cy="690" r="4"/>
      </g>
      <g class="net-accent">
        <circle cx="300" cy="120" r="5"/><circle cx="1100" cy="520" r="5"/><circle cx="700" cy="700" r="5"/>
      </g>
      <!-- sparklines -->
      <path class="spark" d="M70 760 L150 720 L210 745 L280 660 L350 690 L420 600"/>
      <path class="spark" d="M1020 150 L1090 110 L1150 135 L1230 70 L1300 105 L1370 60"/>
    </svg>
    <div class="container hero-content">
      <h1 class="hero-greet">HI, I'M {firstName.toUpperCase()}</h1>
      <span class="accent-line hero-line"></span>
      <p class="hero-sub">Analyzing and visualizing data to drive better, informed business decisions.</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="#about">About Me</a>
        <a class="btn btn-outline-light" href={withBase("/projects")}>View Projects</a>
      </div>
    </div>
    <a href="#about" class="hero-scroll" aria-label="Scroll down">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M6 13l6 6 6-6"/></svg>
    </a>
  </section>

  <!-- ================= ABOUT ================= -->
  <section class="section" id="about">
    <div class="container about-grid">
      <div class="reveal">
        <span class="about-eyebrow">About Me</span>
        <h2 class="about-h">A business-analytics mind that ships data science.</h2>
        <span class="accent-line"></span>
      </div>
      <div class="about-body reveal">
        <p>
          I'm {site.name}, a final-year <strong>Business Analytics</strong> student at the
          University of Ghana training as a <strong>data scientist and ML engineer</strong>.
          I work across the whole pipeline — from wrangling messy data and building the
          systems that store it, to modeling it and turning the result into something a
          business can act on.
        </p>
        <p>
          My favourite problems sit where statistics meets a real decision: reading public
          sentiment from social media, finding the levers that move retail revenue, and
          building Power BI dashboards that make a year of operations legible at a glance.
          I've also presented at the <strong>University of Calgary</strong> on empowering
          global innovation through AI, data science, and analytics.
        </p>

        <div class="about-stacks">
          <div class="stack">
            <h4>Data Science &amp; ML</h4>
            <div class="tag-row">
              <span class="tag">Python</span><span class="tag">pandas</span>
              <span class="tag">scikit-learn</span><span class="tag">NLTK</span>
              <span class="tag">Gensim</span>
            </div>
          </div>
          <div class="stack">
            <h4>Analytics &amp; BI</h4>
            <div class="tag-row">
              <span class="tag">Power BI</span><span class="tag">DAX</span>
              <span class="tag">EDA</span><span class="tag">Statistics</span>
            </div>
          </div>
          <div class="stack">
            <h4>Data Foundations</h4>
            <div class="tag-row">
              <span class="tag">SQL</span><span class="tag">Databases</span>
              <span class="tag">Data Quality</span><span class="tag">Governance</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= FEATURED PROJECTS ================= -->
  <section class="section section-alt" id="projects">
    <div class="container">
      <div class="section-head reveal">
        <h2>Projects</h2>
        <p>A sample of my data science, analytics, and Power BI work.</p>
      </div>

      <div class="project-grid">
        {featured.map((p) => (
          <ProjectCard
            href={`/projects/${p.id}`}
            title={p.data.title}
            summary={p.data.summary}
            category={p.data.category}
            date={p.data.date}
            cover={p.data.cover}
          />
        ))}
      </div>

      <div class="all-projects-cta reveal">
        <a class="btn btn-ghost" href={withBase("/projects")}>See all projects</a>
      </div>
    </div>
  </section>

  <!-- ================= CONTACT ================= -->
  <section class="section" id="contact">
    <div class="container contact-inner reveal">
      <span class="about-eyebrow">Get In Touch</span>
      <h2>Let's build something with your data.</h2>
      <span class="accent-line" style="margin-inline:auto"></span>
      <p class="contact-lead">
        Open to data science, ML, and analytics roles and internships. The fastest way to
        reach me is email — I reply quickly.
      </p>
      <div class="contact-actions">
        <a class="btn btn-primary" href={`mailto:${site.email}`}>Email Me</a>
        {site.linkedin && <a class="btn btn-ghost" href={site.linkedin} target="_blank" rel="noopener">LinkedIn</a>}
        {site.github && <a class="btn btn-ghost" href={site.github} target="_blank" rel="noopener">GitHub</a>}
      </div>
    </div>
  </section>
</Base>

<style>
  /* ---- Hero ---- */
  .hero {
    position: relative;
    isolation: isolate;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
    color: #fff;
    background-color: #0c0d13;
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
  }
  /* Dark gradient over the glass photo: edges dark for legibility, centre
     left a touch open so the warm glow reads behind the headline. */
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background:
      radial-gradient(120% 95% at 50% 42%, rgba(12, 13, 19, 0.30), rgba(12, 13, 19, 0.82) 82%),
      linear-gradient(180deg, rgba(12, 13, 19, 0.62), rgba(12, 13, 19, 0.30) 38%, rgba(12, 13, 19, 0.80));
  }

  /* Data-science network motif */
  .hero-net {
    position: absolute;
    inset: 0;
    z-index: -1;
    width: 100%;
    height: 100%;
    pointer-events: none;
    /* Fade out toward the centre so the headline stays clean */
    -webkit-mask-image: radial-gradient(58% 58% at 50% 44%, transparent 28%, #000 76%);
    mask-image: radial-gradient(58% 58% at 50% 44%, transparent 28%, #000 76%);
  }
  .hero-net .net-edges path { stroke: rgba(255, 255, 255, 0.14); stroke-width: 1; fill: none; }
  .hero-net .net-nodes circle { fill: rgba(255, 255, 255, 0.45); }
  .hero-net .net-accent circle {
    fill: var(--accent);
    animation: nodePulse 3.5s ease-in-out infinite;
  }
  .hero-net .net-accent circle:nth-child(2) { animation-delay: 1.2s; }
  .hero-net .net-accent circle:nth-child(3) { animation-delay: 2.2s; }
  .hero-net .spark { stroke: rgba(232, 85, 61, 0.55); stroke-width: 2; fill: none; stroke-linecap: round; stroke-linejoin: round; }
  @keyframes nodePulse {
    0%, 100% { opacity: 0.5; r: 5; }
    50% { opacity: 1; r: 7; }
  }
  @media (prefers-reduced-motion: reduce) { .hero-net .net-accent circle { animation: none; } }
  .hero-content { position: relative; z-index: 1; display: flex; flex-direction: column; align-items: center; }
  .hero-greet {
    color: #fff;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.01em;
  }
  .hero-line { margin: 26px 0; }
  .hero-sub {
    color: rgba(255, 255, 255, 0.92);
    font-size: clamp(1.05rem, 2.2vw, 1.3rem);
    max-width: 620px;
    margin-bottom: 38px;
  }
  .hero-actions { display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; }

  .hero-scroll {
    position: absolute;
    bottom: 30px; left: 50%; transform: translateX(-50%);
    z-index: 1;
    color: rgba(255, 255, 255, 0.8);
    animation: bob 2s var(--ease) infinite;
  }
  .hero-scroll svg { width: 30px; height: 30px; }
  @keyframes bob { 0%,100% { transform: translate(-50%, 0); } 50% { transform: translate(-50%, 8px); } }
  @media (prefers-reduced-motion: reduce) { .hero-scroll { animation: none; } }

  /* ---- About ---- */
  .about-grid { display: grid; grid-template-columns: 0.85fr 1.15fr; gap: 60px; align-items: start; }
  .about-eyebrow {
    font-family: var(--font-display);
    font-size: 0.78rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--accent);
  }
  .about-h { margin: 14px 0 18px; }
  .about-body p { margin-bottom: 18px; font-size: 1.05rem; }
  .about-body strong { color: var(--ink); font-weight: 600; }
  .about-stacks { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 26px; }
  .stack h4 {
    font-family: var(--font-display);
    font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.06em;
    color: var(--ink); margin-bottom: 12px;
  }

  /* ---- Projects ---- */
  .project-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 30px; }
  .all-projects-cta { text-align: center; margin-top: 48px; }

  /* ---- Contact ---- */
  .contact-inner { text-align: center; max-width: 640px; margin: 0 auto; }
  .contact-inner h2 { margin-bottom: 18px; }
  .contact-lead { margin: 22px auto 32px; color: var(--text); font-size: 1.08rem; }
  .contact-actions { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }

  /* ---- Responsive ---- */
  @media (max-width: 900px) {
    .about-grid { grid-template-columns: 1fr; gap: 36px; }
    .project-grid { grid-template-columns: 1fr; }
    .hero { background-attachment: scroll; }
  }
  @media (max-width: 560px) {
    .about-stacks { grid-template-columns: 1fr; gap: 18px; }
  }
</style>
